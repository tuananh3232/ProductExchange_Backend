# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
STAFF_INVITATION_PATH=/shop/invitations
# Optional. Supports {invitationId} and {shopId}; overrides FRONTEND_URL + STAFF_INVITATION_PATH when set.
STAFF_INVITATION_URL_TEMPLATE=

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/productexchange
DB_NAME=productexchange

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=30d

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=ProductExchange

# Google OAuth
GOOGLE_CLIENT_ID=

# VNPay
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=DEMO
VNPAY_HASH_SECRET=DEMO_HASH_SECRET
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_CURR_CODE=VND
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other
VNPAY_RETURN_URL=http://localhost:3000/api/v1/payments/vnpay/return
VNPAY_IPN_URL=http://localhost:3000/api/v1/payments/vnpay/ipn

# PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/api/v1/payments/payos/return
PAYOS_CANCEL_URL=http://localhost:3000/api/v1/payments/payos/cancel
